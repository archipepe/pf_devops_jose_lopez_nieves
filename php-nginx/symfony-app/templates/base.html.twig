<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
        <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
        <title>{% block title %}Mi Tienda Online{% endblock %}</title>
        {% block styles %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
            <link rel="stylesheet" href="{{ asset('css/carrito-badge.css') }}">
        {% endblock %}
    </head>
    <body>
        <header>
            <div class="header-container">
                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                    <h1><a class="main-nav-link" href="{{ path('index') }}">Mi Tienda Online</a></h1>
                    <button class="menu-toggle" id="menuToggle" aria-label="Menú" aria-expanded="false">
                        ☰
                    </button>
                    <nav id="mainNavDesktop" aria-label="Navegación principal">
                        {% include "base.nav.html.twig" %}
                    </nav>
                </div>
                <nav id="mainNavMobile" aria-label="Navegación principal">
                    {% include "base.nav.html.twig" %}
                </nav>
            </div>
        </header>
        
        <main>
            {% block body %}{% endblock %}
            
            {# Contenedor para notificaciones #}
            <div class="notification-container" id="notificationContainer"></div>
        </main>
        
        <footer class="footer {% if deployment_colour is defined %}footer-{{ deployment_colour }}{% endif %}">
            <div class="footer-content">
                <div class="footer-info">
                    <p>Proyecto Final DevOps | José López Nieves</p>
                    <div class="deployment-info">
                        <span class="deployment-badge {% if deployment_colour == 'blue' %}badge-blue{% elseif deployment_colour == 'green' %}badge-green{% else %}badge-default{% endif %}">
                            {% if deployment_colour == 'blue' %}
                                🔵 Blue Deployment
                            {% elseif deployment_colour == 'green' %}
                                🟢 Green Deployment
                            {% else %}
                                ⚪ Deployment: {{ deployment_name|default('unknown') }}
                            {% endif %}
                        </span>
                        <span class="pod-info">Pod: {{ pod_name|default('unknown') }}</span>
                        <span class="zone-info">Zona: {{ pod_zone|default('unknown') }}</span>
                        <span class="node-info">Nodo: {{ node_name|default('unknown') }}</span>
                        <span class="version-info">Versión: {{ app_version|default('1.0.0') }}</span>
                    </div>
                </div>
            </div>
        </footer>
        
        {% block javascripts %}
            <script type="text/javascript" src="{{ asset('js/carrito-listener.js') }}"></script>
            <script type="text/javascript" src="{{ asset('js/home.js') }}"></script>
        {% endblock %}
    </body>
</html>