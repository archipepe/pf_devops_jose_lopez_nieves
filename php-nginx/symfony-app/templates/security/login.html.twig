{% extends 'base.html.twig' %}

{% block title %}Iniciar Sesión - Mi Tienda Online{% endblock %}

{% block body %}
<section class="login-section">
    <div class="login-container">
        <div class="login-form-wrapper">
            <h1 class="login-title">Iniciar Sesión</h1>
            
            {% if error %}
                <div class="alert alert-error">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}
            
            <form method="post" class="login-form">
                <div class="form-group">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" 
                           name="email" 
                           id="email" 
                           class="form-control" 
                           placeholder="tu@email.com" 
                           value="{{ last_username }}"
                           required 
                           autofocus>
                </div>
                
                <div class="form-group">
                    <label for="password" class="form-label">Contraseña</label>
                    <input type="password" 
                           name="password" 
                           id="password" 
                           class="form-control" 
                           placeholder="••••••••" 
                           required>
                </div>

                <input type="hidden" name="_csrf_token"
                    value="{{ csrf_token('authenticate') }}"
                >
                
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-block">
                        Iniciar Sesión
                    </button>
                </div>
                
                <div class="login-links">
                    <a href="{{ path('app_register') }}" class="link">Registrarse</a>
                </div>
                <div class="login-links">
                    <a href="{{ path('index') }}" class="link">Volver a la tienda</a>
                </div>
            </form>
            
            <!-- Credenciales de demo (solo para desarrollo) -->
            <div class="demo-credentials">
                <p><small>Demo: abraca_admin@example.com / tada</small></p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
